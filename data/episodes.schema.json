{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Frontier episodes index",
  "type": "object",
  "required": ["schema_version", "language", "updated_at", "episodes"],
  "properties": {
    "schema_version": { "type": "string" },
    "language": { "type": "string", "enum": ["ko"] },
    "updated_at": { "type": ["string", "null"] },
    "source": {
      "type": "object",
      "properties": {
        "sitemap": { "type": "string" },
        "llms_txt": { "type": "string" }
      }
    },
    "episodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ep_id", "url", "status"],
        "properties": {
          "ep_id": { "type": "integer" },
          "url": { "type": "string" },
          "title": { "type": ["string", "null"] },
          "published_date": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["discovered", "fetched", "extracted", "rendered"]
          },
          "content_hash": { "type": ["string", "null"] },
          "last_seen": { "type": ["string", "null"] }
        }
      }
    }
  }
}
