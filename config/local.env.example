# aifrontier-wiki local environment (copy to local.env; never commit local.env)
# DeepSeek Pro / Hermes OpenAI-compatible endpoint used by `extract --allow-llm --adapter deepseek`
AIFRONTIER_LLM_BASE_URL=http://localhost:8000/v1
AIFRONTIER_LLM_MODEL=deepseek-pro
AIFRONTIER_LLM_API_KEY=

# Optional fetch politeness overrides
AIFRONTIER_FETCH_USER_AGENT=aifrontier-wiki/phase1 personal-research
AIFRONTIER_FETCH_DELAY_SECONDS=2
