# aifrontier-wiki local environment
# Copy to config/local.env; never commit config/local.env

# OpenAI-compatible LLM endpoint used by `extract --allow-llm --adapter deepseek`
AIFRONTIER_LLM_BASE_URL=http://localhost:8000/v1
AIFRONTIER_LLM_MODEL=deepseek-pro
AIFRONTIER_LLM_API_KEY=replace-me

# Optional fetch politeness overrides
AIFRONTIER_FETCH_USER_AGENT=aifrontier-wiki personal-research
AIFRONTIER_FETCH_DELAY_SECONDS=2
